<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- GIỮ NGUYÊN code của bạn - Kế thừa view accounting.report để thêm button -->
    <record id="accounting_report_view_inherit_b01dn" model="ir.ui.view">
        <field name="name">accounting.report.view.inherit.b01dn</field>
        <field name="model">accounting.report</field> 
        <field name="inherit_id" ref="accounting_pdf_reports.accounting_report_view"/>
        <field name="arch" type="xml">
            <xpath expr="//footer/button[@name='check_report']" position="after">
                <button name="action_export_b01dn_excel" 
                        string="Bảng Cân Đối Kế Toán (B01-DN) - Excel" 
                        type="object" 
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <!-- THÊM MỚI: Action cho Balance Sheet Wizard -->
    <record id="action_balance_sheet_b01dn" model="ir.actions.act_window">
        <field name="name">Bảng Cân Đối Kế Toán (B01-DN)</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">adecsol.balance.sheet.export</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <!-- THÊM MỚI: Form view cho Balance Sheet Wizard -->
    <record id="view_balance_sheet_b01dn_form" model="ir.ui.view">
        <field name="name">adecsol.balance.sheet.export.form</field>
        <field name="model">adecsol.balance.sheet.export</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="date_from" required="1"/>
                            <field name="date_to" required="1"/>
                        </group>
                        <group>
                            <field name="company_id" 
                                   options="{'no_create': True}"
                                   groups="base.group_multi_company"/>
                            <field name="target_move"/>
                        </group>
                        <group>
                            <field name="enable_comparison"/>
                            <field name="display_debit_credit"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_export_xlsx" 
                            string="Xuất Excel" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Hủy" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- THÊM MỚI: Menu item (nếu muốn thêm vào menu Reports) -->
    <menuitem id="menu_balance_sheet_b01dn"
              name="Bảng Cân Đối Kế Toán (B01-DN)"
              parent="account.menu_finance_reports"
              action="action_balance_sheet_b01dn"
              sequence="15"/>
</odoo>