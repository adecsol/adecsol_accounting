<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fyc_form_inherit_adecsol" model="ir.ui.view">
        <field name="name">account.fiscalyear.closing.form.inherit.adecsol</field>
        <field name="model">account.fiscalyear.closing</field>
        <field name="inherit_id" ref="account_fiscal_year_closing.view_account_fiscalyear_closing_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(account.action_account_moves_all_a)d" 
                        type="action" class="oe_stat_button" icon="fa-usd"
                        context="{'search_default_posted': 1, 'search_default_account_type': 'income'}"
                        domain="[('account_id.account_type', '=', 'income'), ('date', '&gt;=', date_start), ('date', '&lt;=', date_end), ('company_id', '=', company_id)]">
                    <div class="o_stat_info">
                        <field name="revenue_amount" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                        <span class="o_stat_text">Revenue</span>
                    </div>
                </button>
                <button name="%(account.action_account_moves_all_a)d" 
                        type="action" class="oe_stat_button" icon="fa-shopping-cart"
                        context="{'search_default_posted': 1, 'search_default_account_type': 'expense'}"
                        domain="[('account_id.account_type', 'in', ['expense', 'expense_direct_cost', 'expense_depreciation']), ('date', '&gt;=', date_start), ('date', '&lt;=', date_end), ('company_id', '=', company_id)]">
                    <div class="o_stat_info">
                        <field name="expense_amount" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                        <span class="o_stat_text">Expenses</span>
                    </div>
                </button>
            </xpath>

            <xpath expr="//field[@name='move_config_ids']/list/field[@name='journal_id']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Journal</attribute>
                <attribute name="optional">show</attribute>
            </xpath>

            <xpath expr="//field[@name='move_config_ids']/form//field[@name='journal_id']" position="attributes">
                <attribute name="required">1</attribute>
                <attribute name="string">Journal</attribute>
            </xpath>

        </field>
    </record>
</odoo>