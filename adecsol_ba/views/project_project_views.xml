                            <!-- Technical Documents -->
                            <div class="col">
                                <!-- CURRENT -->
                                <div style="border: 3px solid #00A09D; padding: 10px; border-radius: 10px; background-color: #f0fdfc; height: 100%;"
                                     invisible="ba_current_step != 'fsd_data'">
<h6 class="fw-bold mb-3 text-center">Technical Documents</h6>

