                                <field name="name"/>
                                <field name="member_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                <button name="action_quick_mom" type="object" string="Quick Meeting"
                                        icon="fa-comments" class="btn-link"
                                        title="Create minutes with this team"
                                        invisible="not id"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Project — Kanban: click opens form view (not tasks)
         ══════════════════════════════════════════════════════ -->

    <record id="project_project_kanban_inherit_ba" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.ba</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <!-- Remove the custom JS class and the action redirect so
                 double-click opens the standard form view -->
            <xpath expr="//kanban" position="attributes">
                <attribute name="js_class"/>
                <attribute name="action"/>
                <attribute name="type"/>
            </xpath>

            <!-- Declare BA fields -->
            <xpath expr="//field[@name='allow_milestones']" position="after">
                <field name="ba_current_step"/>
                <field name="ba_progress"/>
                <field name="mom_count"/>
                <field name="survey_count"/>
                <field name="fsd_count"/>
                <field name="fitgap_count"/>
                <field name="handover_count"/>
                <field name="pending_fsd_count"/>
                <field name="pending_survey_count"/>
                <field name="draft_handover_count"/>
                <field name="ba_manager_id"/>
            </xpath>

            <!-- Inject BA section before the footer -->
            <xpath expr="//footer[hasclass('mt-auto')]" position="before">
                <div t-if="record.ba_current_step.raw_value" class="px-1 pb-2 mt-1">
                    <!-- Phase badge + Progress bar -->
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <field name="ba_current_step" widget="badge"
                               decoration-info="ba_current_step == 'survey'"
                               decoration-primary="ba_current_step == 'design'"
                               decoration-warning="ba_current_step == 'fsd_data'"
                               decoration-danger="ba_current_step == 'approval_handover'"
                               decoration-success="ba_current_step == 'plan_update'"/>
                        <div class="flex-grow-1">
                            <div class="progress" style="height: 6px; border-radius: 3px;">
                                <div class="progress-bar bg-success" role="progressbar"
                                     t-attf-style="width: #{record.ba_progress.raw_value}%;"/>
                            </div>
                        </div>
                        <small class="fw-bold text-success">
                            <t t-out="record.ba_progress.raw_value"/>%
                        </small>
                    </div>

                    <!-- Clickable metrics row -->
                    <div class="d-flex flex-wrap gap-1 mb-1">
                        <button name="action_view_mom" type="object"
                                class="btn btn-sm btn-outline-secondary py-0 px-1"
                                style="font-size: 11px;"
                                title="Meeting Minutes">
                            <i class="fa fa-pencil-square-o me-1"/>
                            <t t-out="record.mom_count.raw_value"/>
                        </button>
                        <button name="action_view_survey" type="object"
                                class="btn btn-sm btn-outline-secondary py-0 px-1"
                                style="font-size: 11px;"
                                title="Survey">
                            <i class="fa fa-clipboard me-1"/>
                            <t t-out="record.survey_count.raw_value"/>
                        </button>
                        <button name="action_view_fitgap" type="object"
                                class="btn btn-sm btn-outline-secondary py-0 px-1"
                                style="font-size: 11px;"
                                title="FIT-GAP">
                            <i class="fa fa-balance-scale me-1"/>
                            <t t-out="record.fitgap_count.raw_value"/>
                        </button>
                        <button name="action_view_fsd" type="object"
                                class="btn btn-sm btn-outline-secondary py-0 px-1"
                                style="font-size: 11px;"
                                title="FSD">
                            <i class="fa fa-file-text-o me-1"/>
                            <t t-out="record.fsd_count.raw_value"/>
                        </button>
                        <button name="action_open_handover_list" type="object"
                                class="btn btn-sm btn-outline-secondary py-0 px-1"
                                style="font-size: 11px;"
                                title="Handover">
                            <i class="fa fa-wrench me-1"/>
                            <t t-out="record.handover_count.raw_value"/>
                        </button>
                    </div>

                    <!-- Pending alerts -->
                    <div t-if="record.pending_fsd_count.raw_value or record.pending_survey_count.raw_value or record.draft_handover_count.raw_value"
                         class="small">
                        <button name="action_dashboard_view_pending_fsd" type="object"
                                class="btn btn-sm btn-link text-warning fw-bold p-0 d-block text-start"
                                style="font-size: 11px;"
                                t-if="record.pending_fsd_count.raw_value">
                            <i class="fa fa-clock-o me-1"/>
                            <t t-out="record.pending_fsd_count.raw_value"/> FSD pending
                        </button>
                        <button name="action_dashboard_view_pending_survey" type="object"
                                class="btn btn-sm btn-link text-info p-0 d-block text-start"
                                style="font-size: 11px;"
                                t-if="record.pending_survey_count.raw_value">
                            <i class="fa fa-send-o me-1"/>
                            <t t-out="record.pending_survey_count.raw_value"/> Survey pending
                        </button>
                        <button name="action_dashboard_view_draft_handover" type="object"
                                class="btn btn-sm btn-link text-muted p-0 d-block text-start"
                                style="font-size: 11px;"
                                t-if="record.draft_handover_count.raw_value">
                            <i class="fa fa-code-fork me-1"/>
                            <t t-out="record.draft_handover_count.raw_value"/> Handover draft
                        </button>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
