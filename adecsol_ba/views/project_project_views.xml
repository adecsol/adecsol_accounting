<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         Project — Smart Buttons for BA documents
         ══════════════════════════════════════════════════════ -->

    <record id="project_project_form_inherit_ba" model="ir.ui.view">
        <field name="name">project.project.form.inherit.ba</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <!-- MoM Smart Button - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_mom" icon="fa-pencil-square-o"
                        groups="adecsol_ba.group_ba_user">
                    <field name="mom_count" widget="statinfo" string="MoM"/>
                </button>

                <!-- Survey Smart Button - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_survey" icon="fa-clipboard"
                        context="{'search_default_project_id': id, 'default_project_id': id}"
                        groups="adecsol_ba.group_ba_user">
                    <field name="survey_count" widget="statinfo" string="Survey"/>
                </button>

                <!-- FSD Smart Button - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_fsd" icon="fa-file-text-o"
                        context="{'search_default_project_id': id, 'default_project_id': id}"
                        groups="adecsol_ba.group_ba_user">
                    <field name="fsd_count" widget="statinfo" string="FSD"/>
                </button>

                <!-- FIT-GAP Smart Button - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_fitgap" icon="fa-balance-scale"
                        context="{'search_default_project_id': id, 'default_project_id': id}"
                        groups="adecsol_ba.group_ba_user">
                    <field name="fitgap_count" widget="statinfo" string="FIT-GAP"/>
                </button>

                <!-- Master Data Smart Button - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_master_data" icon="fa-database"
                        context="{'search_default_project_id': id, 'default_project_id': id}"
                        groups="adecsol_ba.group_ba_user">
                    <field name="master_data_count" widget="statinfo" string="Master Data"/>
                </button>

                <!-- Knowledge - only BA -->
                <button class="oe_stat_button" type="object"
                        name="action_view_knowledge" icon="fa-book"
                        invisible="not document_page_category_id"
                        groups="adecsol_ba.group_ba_user">
                    <field name="document_page_count" widget="statinfo" string="Knowledge"/>
                </button>
                <button class="oe_stat_button" type="object"
                        name="action_create_knowledge_category" icon="fa-book"
                        invisible="document_page_category_id"
                        groups="adecsol_ba.group_ba_user">
                    <span class="o_stat_text">Create Knowledge</span>
                </button>
            </xpath>
            <!-- Always show Customer -->
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            
            <!-- Link to Knowledge Category - display after Project Manager -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="document_page_category_id"
                       string="📚 Knowledge Category"
                       options="{'no_create': True, 'open_target': 'new'}"
                       invisible="1"
                       readonly="1"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="ba_process_page" string="Analysis Process"
                      groups="adecsol_ba.group_ba_user">
                    <header>
                        <field name="ba_current_step" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <div style="margin-top: 15px; margin-bottom: 25px;">
                        <field name="has_mom" invisible="1"/>
                        <field name="has_survey" invisible="1"/>
                        <field name="has_tobe" invisible="1"/>
                        <field name="has_fitgap" invisible="1"/>
                        <field name="has_fsd" invisible="1"/>
                        <field name="has_master_data" invisible="1"/>
                        <field name="has_signoff" invisible="1"/>
                        <field name="has_handover" invisible="1"/>
                        <field name="has_wbs" invisible="1"/>
                        <div class="row mt-3 align-items-stretch">

                            <!-- In-depth Survey -->
                            <div class="col">
                                <!-- CURRENT -->
                                <div style="border: 3px solid #00A09D; padding: 10px; border-radius: 10px; background-color: #f0fdfc; height: 100%;"
                                     invisible="ba_current_step != 'survey'">
<h6 class="fw-bold mb-3 text-center">In-depth Survey</h6>

                                    <div class="mb-3">
                                        <div class="text-muted small fw-bold mb-1">1. Interview (MoM)</div>
                                        <div class="d-flex w-100" style="gap: 4px;">
                                            <button name="action_view_mom" type="object" class="btn btn-sm btn-success flex-grow-1" invisible="not has_mom" string="View" icon="fa-list"/>
                                            <button name="action_view_mom" type="object" class="btn btn-sm btn-secondary flex-grow-1" invisible="has_mom" string="View" icon="fa-list"/>
                                            <button name="action_quick_create_mom" type="object" class="btn btn-sm btn-outline-primary" icon="fa-plus" title="Create new"/>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="text-muted small fw-bold mb-1">2. AS-IS Analysis</div>
                                        <div class="d-flex w-100" style="gap: 4px;">
                                            <button name="%(adecsol_ba.ba_customer_survey_action)d" type="action" context="{'search_default_project_id': id, 'default_project_id': id}"
                                                    class="btn btn-sm btn-success flex-grow-1" invisible="not has_survey" string="View" icon="fa-list"/>
                                            <button name="%(adecsol_ba.ba_customer_survey_action)d" type="action" context="{'search_default_project_id': id, 'default_project_id': id}"
