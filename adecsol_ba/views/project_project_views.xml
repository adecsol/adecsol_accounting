                </page>
                <page name="wbs_page" string="WBS (Technical Handover)"
                      groups="adecsol_ba.group_ba_user">
                    <field name="handover_ids">
                        <list editable="bottom">
                            <field name="name" readonly="state == 'confirmed'"/>
                            <button name="action_open_form" string="" type="object"
                                    icon="fa-external-link" class="btn-link"
                                    title="Open full form"/>
                            <field name="feature_id" string="Feature" readonly="state == 'confirmed'"/>
                            <field name="fsd_id" string="FSD" readonly="state == 'confirmed'"/>
                            <field name="planned_hours" widget="float_time" string="Planned Hours" sum="Total" readonly="state == 'confirmed'"/>
                            <field name="assignee_id" string="Assignee" readonly="state == 'confirmed'"/>
                            <field name="date" readonly="state == 'confirmed'"/>
                            <field name="task_id" string="Task" readonly="1"/>
                            <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
                            <button name="action_confirm" string="Confirm" type="object"
                                    icon="fa-check" class="btn-link text-success"
                                    title="Confirm handover &amp; generate tasks"
                                    invisible="state != 'draft'"/>
                        </list>
                    </field>
                </page>

                <page name="ba_teams_config" string="Teams &amp; Access" groups="adecsol_ba.group_ba_user">
                    <group string="Role Assignment">
                        <label for="ba_manager_id"/>
                        <div class="d-flex align-items-center w-100">
                            <field name="ba_manager_id" widget="many2one_avatar" class="oe_inline"/>
                            <button name="action_quick_mom_role" type="object" string="Quick Meeting" icon="fa-comments" 
