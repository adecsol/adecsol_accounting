<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════
         A1.MoM.01 — Meeting Minutes Views
         ══════════════════════════════════════════════════════ -->

    <!-- Form View -->
    <record id="ba_mom_view_form" model="ir.ui.view">
        <field name="name">ba.mom.form</field>
        <field name="model">ba.mom</field>
        <field name="arch" type="xml">
            <form string="Meeting Minutes (A1.MoM.01)">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object" class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-secondary"
                            invisible="state not in ('draft', 'confirmed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Meeting subject..." readonly="state in ('approved', 'cancel')"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="project_id" readonly="state in ('approved', 'cancel')"/>
                            <field name="project_team_id" readonly="state in ('approved', 'cancel')"/>
                            <field name="partner_id"/>
                            <field name="start_date" widget="daterange" options="{'end_date_field': 'stop_date'}" readonly="state in ('approved', 'cancel')"/>
                            <field name="stop_date" invisible="1"/>
                        </group>
                        <group string="Meeting Format">
                            <field name="meeting_format" widget="radio" options="{'horizontal': True}" readonly="state in ('approved', 'cancel')"/>
                            <field name="meeting_location" invisible="meeting_format != 'offline'" readonly="state in ('approved', 'cancel')"/>
                            <field name="meeting_url" widget="url" invisible="meeting_format != 'online'"
                               placeholder="https://meet.google.com/... or Zoom link"
                               readonly="state in ('approved', 'cancel')"/>
                        </group>
                    </group>
                    <group>
                        <group string="Attendees">
                            <field name="attendee_ids" widget="many2many_tags" readonly="state in ('approved', 'cancel')"/>
                            <field name="note_take_partner_id"
                                   domain="[('id', 'in', attendee_ids)]"
                                   readonly="state in ('approved', 'cancel')"/>
                        </group>
                        <group string="Links &amp; Templates">
                            <label for="document_page_id" string="Knowledge"/>
                            <div class="d-flex align-items-center gap-1">
                                <field name="document_page_id" nolabel="1" readonly="1" class="flex-grow-1"/>
                                <button name="action_preview_knowledge_document" type="object"
                                        icon="fa-eye" class="btn-link p-0"
                                        title="Preview Knowledge Document"
                                        invisible="not document_page_id"/>
                            </div>
                            <label for="knowledge_template_id" string="Knowledge Template" invisible="document_page_id"/>
                            <div class="d-flex align-items-center gap-1" invisible="document_page_id">
                                <field name="knowledge_template_id" nolabel="1"
                                       readonly="state in ('approved', 'cancel')" class="flex-grow-1"/>
                                <button name="action_preview_knowledge_template" type="object"
                                        icon="fa-eye" class="btn-link p-0"
                                        title="Preview Knowledge Template"
                                        invisible="not id"/>
                            </div>
                        </group>
                    </group>
                    <group invisible="1">
                        <field name="calendar_event_id" readonly="state in ('approved', 'cancel')"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Meeting Minutes" name="content">
                            <field name="content" nolabel="1" readonly="state in ('approved', 'cancel')"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="ba_mom_view_kanban" model="ir.ui.view">
        <field name="name">ba.mom.kanban</field>
        <field name="model">ba.mom</field>
        <field name="arch" type="xml">
            <kanban default_group_by="project_id" class="o_kanban_small_column"
                    quick_create="false">
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="stop_date"/>
                <field name="note_take_partner_id"/>
                <field name="attendee_ids"/>
                <field name="state"/>
                <progressbar field="state"
                             colors='{"draft": "info", "confirmed": "warning", "approved": "success", "cancel": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content p-2">
                            <!-- Header: date + hours -->
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="text-muted small">
                                    <i class="fa fa-calendar me-1" title="From"/>
                                    <field name="start_date" widget="datetime"/>
                                    <br/>
                                    <i class="fa fa-calendar me-1" title="To"/>
                                    <field name="stop_date" widget="datetime"/>
                                </span>
                                <field name="state" widget="badge"
                                       decoration-info="state == 'draft'"
                                       decoration-warning="state == 'confirmed'"
                                       decoration-success="state == 'approved'"
                                       decoration-danger="state == 'cancel'"/>
                            </div>
                            <!-- Title -->
                            <strong class="o_kanban_record_title d-block mb-1">
                                <field name="name"/>
                            </strong>
                            <!-- Project -->
                            <div class="text-muted small mb-1">
                                <i class="fa fa-folder-o me-1" title="Project"/><field name="project_id"/>
                            </div>
                            <div class="text-muted small mb-1" invisible="not partner_id">
                                <i class="fa fa-user me-1" title="Customer"/><field name="partner_id"/>
                            </div>
                            <!-- Footer: note taker + attendee avatar -->
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="text-muted small">
                                    <i class="fa fa-pencil me-1" title="Note taker"/>
                                    <field name="note_take_partner_id"/>
                                </span>
                                <field name="attendee_ids" widget="many2many_avatar"
                                       options="{'limit': 3}"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- list View -->
    <record id="ba_mom_view_list" model="ir.ui.view">
        <field name="name">ba.mom.list</field>
        <field name="model">ba.mom</field>
        <field name="arch" type="xml">
            <list string="Meeting Minutes" decoration-info="state == 'draft'"
                  decoration-success="state == 'approved'"
                  decoration-muted="state == 'cancel'">
                <field name="start_date"/>
                <field name="stop_date"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id" optional="show"/>
                <field name="note_take_partner_id"/>
                <field name="attendee_ids" widget="many2many_tags"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- Search -->
    <record id="ba_mom_view_search" model="ir.ui.view">
        <field name="name">ba.mom.search</field>
        <field name="model">ba.mom</field>
        <field name="arch" type="xml">
            <search string="Search Meeting Minutes">
                <field name="name"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <separator/>
                <filter name="filter_draft" string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter name="filter_approved" string="Approved"
                        domain="[('state','=','approved')]"/>
                <filter name="filter_cancel" string="Cancelled"
                        domain="[('state','=','cancel')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project"
                            context="{'group_by':'project_id'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by':'partner_id'}"/>
                    <filter name="group_state" string="Status"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="ba_mom_action" model="ir.actions.act_window">
        <field name="name">Meeting Minutes</field>
        <field name="res_model">ba.mom</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="ba_mom_view_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create first meeting minutes
            </p>
        </field>
    </record>

</odoo>
