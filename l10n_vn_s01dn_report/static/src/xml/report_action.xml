<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="web.ReportAction" t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='print']" position="replace">
            <button
                t-if="isS01dnHtmlReport"
                t-on-click="exportS01dnTT200"
                type="button"
                class="btn btn-primary"
                title="Export general ledger (S01-DN) to Excel"
            >General ledger (S01-DN) (.xlsx)</button>
            <button
                t-if="isS01dnHtmlReport"
                t-on-click="printS01dnBrowser"
                type="button"
                class="btn btn-secondary ms-2"
                title="Print in browser: Excel-style header on page 1, footer and signatures on last page; 2–3 accounts per page (A4 landscape)."
            >Print</button>
            <button
                t-if="!isS01dnHtmlReport"
                t-on-click="print"
                type="button"
                class="btn btn-primary"
                title="Print"
            >Print</button>
        </xpath>
    </t>
</templates>
