<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="web.ReportAction" t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='print']" position="replace">
            <button
                t-if="isS01dnHtmlReport"
                t-on-click="exportS01dnTT200"
                type="button"
                class="btn btn-primary"
                title="Xuất excel Nhật ký - Sổ Cái (S01-DN)"
            >Nhật ký - Sổ Cái (S01-DN) (.xlsx)</button>
            <button
                t-if="isS01dnHtmlReport"
                t-on-click="printS01dnBrowser"
                type="button"
                class="btn btn-secondary ms-2"
                title="In trong trình duyệt: header Excel trang 1, footer + chữ ký trang cuối; 2–3 TK/trang tự chọn theo độ rộng A4 ngang"
            >In</button>
            <button
                t-if="!isS01dnHtmlReport"
                t-on-click="print"
                type="button"
                class="btn btn-primary"
                title="Print"
            >Print</button>
        </xpath>
    </t>
</templates>
