<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Journal – General Ledger S01-DN (XLSX) -->
    <record id="general_ledger_s01dn_xlsx_action" model="ir.actions.report">
        <field name="name">Journal – General Ledger (S01-DN)</field>
        <field name="model">general.ledger.report.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">l10n_vn_s01dn_report.general_ledger_s01dn_xlsx</field>
        <field name="report_file">Journal_Ledger_S01_DN</field>
        <field name="print_report_name">'Journal_Ledger_S01_DN_%s_%s' % ((object.date_from.strftime('%d%m%Y') if object.date_from else ''), (object.date_to.strftime('%d%m%Y') if object.date_to else ''))</field>
        <field name="binding_type">report</field>
    </record>

    <!-- Journal – General Ledger S01-DN (QWeb HTML) -->
    <record id="general_ledger_s01dn_html_action" model="ir.actions.report">
        <field name="name">Journal – General Ledger S01-DN (summary)</field>
        <field name="model">general.ledger.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">l10n_vn_s01dn_report.general_ledger_s01dn</field>
        <field name="report_file">l10n_vn_s01dn_report.general_ledger_s01dn</field>
        <field name="print_report_name">'Journal_Ledger_S01_DN_%s_%s' % ((object.date_from.strftime('%d%m%Y') if object.date_from else ''), (object.date_to.strftime('%d%m%Y') if object.date_to else ''))</field>
    </record>
</odoo>
