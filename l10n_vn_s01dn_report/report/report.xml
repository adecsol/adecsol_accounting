<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Nhật ký - Sổ Cái S01-DN Report Action (XLSX) -->
    <record id="general_ledger_s01dn_xlsx_action" model="ir.actions.report">
        <field name="name">Nhật ký - Sổ Cái (S01-DN)</field>
        <field name="model">general.ledger.report.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">l10n_vn_s01dn_report.general_ledger_s01dn_xlsx</field>
        <field name="report_file">Nhat_ky_So_Cai_S01_DN</field>
        <!-- Tên file khi tải XLSX (report_xlsx dùng khi có 1 docid): Nhat_ky_So_Cai_S01_DN_YYYYMMDD_YYYYMMDD -->
        <field name="print_report_name">'Nhat_ky_So_Cai_S01_DN_%s_%s' % ((object.date_from.strftime('%d%m%Y') if object.date_from else ''), (object.date_to.strftime('%d%m%Y') if object.date_to else ''))</field>
        <field name="binding_type">report</field>
    </record>

    <!-- Nhật ký - Sổ Cái S01-DN Summary (QWeb HTML) -->
    <record id="general_ledger_s01dn_html_action" model="ir.actions.report">
        <field name="name">Nhật ký - Sổ Cái S01-DN (Tổng hợp)</field>
        <field name="model">general.ledger.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">l10n_vn_s01dn_report.general_ledger_s01dn</field>
        <field name="report_file">l10n_vn_s01dn_report.general_ledger_s01dn</field>
        <!-- Tên file PDF/đính kèm giống XLSX -->
        <field name="print_report_name">'Nhat_ky_So_Cai_S01_DN_%s_%s' % ((object.date_from.strftime('%d%m%Y') if object.date_from else ''), (object.date_to.strftime('%d%m%Y') if object.date_to else ''))</field>
    </record>
</odoo>
