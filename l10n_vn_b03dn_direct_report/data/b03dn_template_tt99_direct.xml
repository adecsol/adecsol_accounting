            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>
    <record id="b03dn_tt99_line_50" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">500</field>
        <field name="code">50</field>
        <field name="name" type="html">
            <p>
                <strong>Net increase (decrease) in cash during the period (50 = 20+30+40)</strong>
            </p>
        </field>
        <field name="sum_expression">20+30+40</field>
    </record>
    <record id="b03dn_tt99_line_50_blank_after" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">501</field>
        <field name="name" type="html">
            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>
    <record id="b03dn_tt99_line_60" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">600</field>
        <field name="code">60</field>
        <field name="name" type="html">
            <p>
                <strong>Cash and cash equivalents at beginning of period</strong>
            </p>
        </field>
        <field name="use_opening_cash_balance" eval="True"/>
    </record>
    <record id="b03dn_tt99_line_60_blank_after" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">601</field>
        <field name="name" type="html">
            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>
    <record id="b03dn_tt99_line_61" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">610</field>
        <field name="code">61</field>
        <field name="name">Effect of foreign exchange rate changes (accounts 413)</field>
        <field name="fx_account_patterns">413%</field>
    </record>
    <record id="b03dn_tt99_line_61_blank_after" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">611</field>
        <field name="name" type="html">
            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>
    <record id="b03dn_tt99_line_70" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">700</field>
        <field name="code">70</field>
