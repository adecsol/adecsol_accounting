<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- B03-DN direct method — line items / account patterns for TT99 (cash flow statement). Optional: enable in __manifest__.py. -->
    <record id="b03dn_template_tt99_direct" model="l10n.vn.b03dn.template">
        <field name="name">B03-DN — Direct method (TT99)</field>
        <field name="circular_type">tt99</field>
        <field name="active" eval="True"/>
    </record>

    <record id="b03dn_tt99_line_h1" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">5</field>
        <field name="code">H1</field>
        <field name="name" type="html">
            <p>
                <strong>I. Cash flows from operating activities</strong>
            </p>
        </field>
        <field name="display_type">line_section</field>
    </record>

    <record id="b03dn_tt99_line_01" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">10</field>
        <field name="code">01</field>
        <field name="name">1. Cash received from sales of goods, services and other operating revenue</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">511%,131%,121%,515%</field>
        <field name="exclude_tag_ids" eval="[(6, 0, [ref('l10n_vn_b03dn_direct_report.tag_b03_cf_22'), ref('l10n_vn_b03dn_direct_report.tag_b03_cf_27')])]"/>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_02" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">20</field>
        <field name="code">02</field>
        <field name="name">2. Cash paid to suppliers for goods and services</field>
        <field name="debit_account_patterns">331%,15%,242%,133%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="exclude_tag_ids" eval="[(6, 0, [ref('l10n_vn_b03dn_direct_report.tag_b03_cf_21_asset')])]"/>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_03" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">30</field>
        <field name="code">03</field>
        <field name="name">3. Cash paid to employees</field>
        <field name="debit_account_patterns">334%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_04" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">40</field>
        <field name="code">04</field>
        <field name="name">4. Interest paid</field>
        <field name="debit_account_patterns">335%,635%,242%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_05" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">50</field>
        <field name="code">05</field>
        <field name="name">5. Corporate income tax paid</field>
        <field name="debit_account_patterns">3334%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_06" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">60</field>
        <field name="code">06</field>
        <field name="name">6. Other cash receipts from operating activities</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">711%,133%,141%,244%,338%</field>
        <field name="exclude_tag_ids" eval="[(6, 0, [ref('l10n_vn_b03dn_direct_report.tag_b03_cf_22')])]"/>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_07" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">70</field>
        <field name="code">07</field>
        <field name="name">7. Other cash payments for operating activities</field>
        <field name="debit_account_patterns">811%,141%,244%,333%,338%,35%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="exclude_account_patterns">3388%</field>
        <field name="amount_multiplier">1</field>
    </record>

    <record id="b03dn_tt99_line_20" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">200</field>
        <field name="code">20</field>
        <field name="name" type="html"><p><strong><em>Net cash from operating activities</em></strong></p>
        </field>
        <field name="sum_expression">01+02+03+04+05+06+07</field>
    </record>
    <record id="b03dn_tt99_line_20_blank_after" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">201</field>
        <field name="name" type="html">
            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>
    <record id="b03dn_tt99_line_h2" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">205</field>
        <field name="code">H2</field>
        <field name="name" type="html">
            <p>
                <strong>II. Cash flows from investing activities</strong>
            </p>
        </field>
        <field name="display_type">line_section</field>
    </record>
    <record id="b03dn_tt99_line_21" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">210</field>
        <field name="code">21</field>
        <field name="name">1. Cash paid for purchase, construction of fixed assets and other long-term assets</field>
        <field name="debit_account_patterns">211%,213%,217%,241%,331%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="exclude_tag_ids" eval="[(6, 0, [ref('l10n_vn_b03dn_direct_report.tag_b03_cf_25'), ref('l10n_vn_b03dn_direct_report.tag_b03_cf_34_loan_principal')])]"/>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_22" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">220</field>
        <field name="code">22</field>
        <field name="name">2. Cash received from disposal of fixed assets and other long-term assets</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">711%,511%,131%</field>
        <field name="exclude_tag_ids" eval="[(6, 0, [ref('l10n_vn_b03dn_direct_report.tag_b03_cf_26')])]"/>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_23" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">230</field>
        <field name="code">23</field>
        <field name="name">3. Cash paid for loans and purchase of debt instruments of other entities</field>
        <field name="debit_account_patterns">128%,171%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_24" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">240</field>
        <field name="code">24</field>
        <field name="name">4. Cash received from collection of loans and sale of debt instruments</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">128%,171%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_25" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">250</field>
        <field name="code">25</field>
        <field name="name">5. Cash paid for capital contributions to other entities</field>
        <field name="debit_account_patterns">221%,222%,228%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_26" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">260</field>
        <field name="code">26</field>
        <field name="name">6. Cash received from return of capital contributions</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">221%,222%,228%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_27" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">270</field>
        <field name="code">27</field>
        <field name="name">7. Receipts of interest, dividends and profit shares</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">515%</field>
        <field name="amount_multiplier">1</field>
    </record>

    <record id="b03dn_tt99_line_30" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">300</field>
        <field name="code">30</field>
        <field name="name" type="html"><p><strong><em>Net cash from investing activities</em></strong></p>
        </field>
        <field name="sum_expression">21+22+23+24+25+26+27</field>
    </record>
    <record id="b03dn_tt99_line_30_blank_after" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">301</field>
        <field name="name" type="html">
            <p><br/></p>
        </field>
        <field name="display_type">line_note</field>
    </record>

    <record id="b03dn_tt99_line_h3" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">305</field>
        <field name="code">H3</field>
        <field name="name" type="html">
            <p>
                <strong>III. Cash flows from financing activities</strong>
            </p>
        </field>
        <field name="display_type">line_section</field>
    </record>
    <record id="b03dn_tt99_line_31" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">310</field>
        <field name="code">31</field>
        <field name="name">1. Cash received from issuance of shares and capital contributions from owners</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">411%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_32" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">320</field>
        <field name="code">32</field>
        <field name="name">2. Cash paid to owners for capital returns and repurchase of issued shares</field>
        <field name="debit_account_patterns">411%,419%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_33" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">330</field>
        <field name="code">33</field>
        <field name="name">3. Cash received from borrowings</field>
        <field name="debit_account_patterns">111%,112%,113%</field>
        <field name="credit_account_patterns">341%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_34" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">340</field>
        <field name="code">34</field>
        <field name="name">4. Cash repayments of borrowings</field>
        <field name="debit_account_patterns">341%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="exclude_account_patterns">3412%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_35" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">350</field>
        <field name="code">35</field>
        <field name="name">5. Cash repayments of finance lease principal</field>
        <field name="debit_account_patterns">3412%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>
    <record id="b03dn_tt99_line_36" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">360</field>
        <field name="code">36</field>
        <field name="name">6. Dividends and profit paid to owners</field>
        <field name="debit_account_patterns">421%,3388%</field>
        <field name="credit_account_patterns">111%,112%,113%</field>
        <field name="amount_multiplier">1</field>
    </record>

    <record id="b03dn_tt99_line_40" model="l10n.vn.b03dn.line">
        <field name="template_id" ref="b03dn_template_tt99_direct"/>
        <field name="sequence">400</field>
