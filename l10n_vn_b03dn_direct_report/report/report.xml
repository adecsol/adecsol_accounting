<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="b03dn_direct_xlsx_action" model="ir.actions.report">
        <field name="name">B03-DN — Cash flow (XLSX)</field>
        <field name="model">l10n.vn.b03dn.report.wizard</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">l10n_vn_b03dn_direct_report.b03dn_direct_xlsx</field>
        <field name="report_file">B03_DN_LCTT</field>
        <field
            name="print_report_name"
        >'B03_DN_LCTT_%s_%s' % (object.date_from.strftime('%d%m%Y') if object.date_from else '', object.date_to.strftime('%d%m%Y') if object.date_to else '')</field>
        <field name="binding_type">report</field>
    </record>

    <record id="b03dn_direct_html_action" model="ir.actions.report">
        <field name="name">Statement of cash flows (B03-DN) (direct)</field>
        <field name="model">l10n.vn.b03dn.report.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">l10n_vn_b03dn_direct_report.b03dn_direct</field>
        <field name="report_file">l10n_vn_b03dn_direct_report.b03dn_direct</field>
        <field
            name="print_report_name"
        >'B03_DN_LCTT_%s_%s' % (object.date_from.strftime('%d%m%Y') if object.date_from else '', object.date_to.strftime('%d%m%Y') if object.date_to else '')</field>
    </record>
</odoo>
