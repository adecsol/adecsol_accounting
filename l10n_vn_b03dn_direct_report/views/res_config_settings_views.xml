<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_circular_type" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.circular_type</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='fiscal_localization_setting_container']" position="after">
                <block
                    title="B03-DN"
                    name="circular_type_setting_container"
                    invisible="not is_root_company"
                >
                    <setting
                        string="Loại thông tư"
                        company_dependent="1"
                        help="Mẫu báo cáo lưu chuyển tiền tệ (B03-DN trực tiếp) chỉ hiển thị các template cùng thông tư."
                    >
                        <field name="circular_type"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
