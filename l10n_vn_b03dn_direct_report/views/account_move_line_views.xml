<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_line_form_b03dn_tags" model="ir.ui.view">
        <field name="name">account.move.line.form.b03dn.tags</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath
                expr="//page[@name='information']/group/group[field[@name='account_id']]"
                position="after"
            >
                <group string="B03-DN — Cash flow tags">
                    <field
                        name="b03dn_cash_flow_tag_ids"
                        widget="many2many_tags"
                        readonly="parent_state != 'draft'"
                    />
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_b03dn_line_tags" model="ir.ui.view">
        <field name="name">account.move.form.b03dn.line.tags</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='line_ids']/list/field[@name='account_id']"
                position="after"
            >
                <field
                    name="b03dn_cash_flow_tag_ids"
                    widget="many2many_tags"
                    optional="show"
                    readonly="parent_state != 'draft'"
                />
            </xpath>
        </field>
    </record>
</odoo>
