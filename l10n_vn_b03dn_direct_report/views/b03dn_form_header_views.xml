<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_vn_b03dn_form_header_tree" model="ir.ui.view">
        <field name="name">l10n.vn.b03dn.form.header.tree</field>
        <field name="model">l10n.vn.b03dn.form.header</field>
        <field name="arch" type="xml">
            <list string="Tiêu đề mẫu biểu B03-DN">
                <field name="name"/>
                <field name="circular_type"/>
                <field name="form_title"/>
            </list>
        </field>
    </record>
    <record id="view_l10n_vn_b03dn_form_header_form" model="ir.ui.view">
        <field name="name">l10n.vn.b03dn.form.header.form</field>
        <field name="model">l10n.vn.b03dn.form.header</field>
        <field name="arch" type="xml">
            <form string="Tiêu đề mẫu biểu B03-DN">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="circular_type"/>
                    </group>
                    <group string="Hiển thị báo cáo (góc phải)">
                        <field name="form_title" colspan="2"/>
                        <field name="legal_reference" colspan="2" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_l10n_vn_b03dn_form_header" model="ir.actions.act_window">
        <field name="name">Tiêu đề mẫu biểu B03-DN</field>
        <field name="res_model">l10n.vn.b03dn.form.header</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="menu_l10n_vn_b03dn_form_header"
        name="Tiêu đề mẫu biểu B03-DN"
        parent="account.menu_finance_configuration"
        action="action_l10n_vn_b03dn_form_header"
        sequence="96"
    />
</odoo>
