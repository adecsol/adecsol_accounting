<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Mở thẳng báo cáo HTML (một lần — chỉnh trên QWeb giống S01-DN) -->
    <record id="action_open_b03dn_html_direct" model="ir.actions.server">
        <field name="name">Báo cáo lưu chuyển tiền tệ (B03-DN trực tiếp)</field>
        <field name="model_id" ref="l10n_vn_b03dn_direct_report.model_l10n_vn_b03dn_report_wizard"/>
        <field name="state">code</field>
        <field name="code">
action = env['l10n.vn.b03dn.report.wizard'].action_open_html_menu()
        </field>
    </record>

    <!-- Form wizard (tuỳ chọn): chỉnh trước khi xem -->
    <record id="accounting_adecsol.action_vn_b03_dn" model="ir.actions.act_window">
        <field name="name">Báo cáo lưu chuyển tiền tệ (B03-DN trực tiếp) — Hộp thoại</field>
        <field name="res_model">l10n.vn.b03dn.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_l10n_vn_b03dn_report_wizard"/>
        <field name="target">new</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>
</odoo>
