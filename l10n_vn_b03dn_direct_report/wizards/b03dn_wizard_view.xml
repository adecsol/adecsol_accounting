<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_vn_b03dn_report_wizard" model="ir.ui.view">
        <field name="name">l10n.vn.b03dn.report.wizard.form</field>
        <field name="model">l10n.vn.b03dn.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Statement of cash flows (B03-DN) (direct)">
                <group>
                    <field name="company_id"/>
                    <field name="template_id"/>
                </group>
                <group string="Report period (current year)">
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <group string="Comparison period (prior year)">
                    <field name="date_from_cmp"/>
                    <field name="date_to_cmp"/>
                </group>
                <group string="Display">
                    <field name="money_unit"/>
                    <field name="signature_date"/>
                </group>
                <footer>
                    <button
                        name="action_open_html"
                        string="View report (HTML)"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_export_xlsx"
                        string="Export Excel"
                        type="object"
                        class="btn-secondary"
                    />
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
