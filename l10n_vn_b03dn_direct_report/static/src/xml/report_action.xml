<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="web.ReportAction" t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='print']" position="before">
            <button
                t-if="isB03dnHtmlReport"
                t-on-click="exportB03dnXlsx"
                type="button"
                class="btn btn-primary ms-2"
                t-att-title="b03dnExportXlsxTitle"
            ><t t-esc="b03dnXlsxButtonLabel"/></button>
        </xpath>
    </t>
</templates>
