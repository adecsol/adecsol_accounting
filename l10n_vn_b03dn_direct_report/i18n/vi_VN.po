#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_07
msgid "7. Other cash payments for operating activities"
msgstr "7. Tiền chi khác cho hoạt động kinh doanh"

#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_27
