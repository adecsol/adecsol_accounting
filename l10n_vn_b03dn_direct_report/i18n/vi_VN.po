#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_21
msgid ""
"1. Cash paid for purchase, construction of fixed assets and other long-term "
"assets"
msgstr "1. Tiền chi mua sắm, xây dựng TSCĐ và các tài sản dài hạn khác"

#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_31
msgid ""
"1. Cash received from issuance of shares and capital contributions from "
"owners"
msgstr "1. Tiền thu từ phát hành cổ phiếu và nhận vốn góp của chủ sở hữu"

#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_01
msgid ""
"1. Cash received from sales of goods, provision of services and business "
"activities"
msgstr "1. Tiền thu từ bán hàng, cung cấp dịch vụ và doanh thu khác"

#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_32
msgid ""
"2. Cash paid to owners for capital returns and repurchase of issued shares"
msgstr ""
"2. Tiền chi trả vốn góp cho các chủ sở hữu, mua lại cổ phiếu của doanh "
"nghiệp đã phát hành"

#. module: l10n_vn_b03dn_direct_report
#: model_terms:l10n.vn.b03dn.line,name:l10n_vn_b03dn_direct_report.b03dn_line_02
