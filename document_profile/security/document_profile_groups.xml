<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_document_profile" model="ir.module.category">
        <field name="name">Document Profile</field>
        <field name="sequence">55</field>
    </record>
    <record id="group_document_profile_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_document_profile"/>
        <field name="comment">View document profile sets, dossiers, and file lines.</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_document_profile_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_document_profile"/>
        <field name="comment">Configure profile sets and manage dossiers and attachments.</field>
        <field name="implied_ids" eval="[(4, ref('group_document_profile_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
